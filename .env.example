# Copiar para .env (nunca commitar o .env real — já está no .gitignore)

# Ligação à base de dados MySQL, formato: mysql://user:password@host:port/database
# Heroku/JawsDB ou AWS RDS normalmente não precisam de DB_SSL.
# Aiven EXIGE TLS: definir DB_SSL=true e, idealmente, DB_SSL_CA.
DB_URL="mysql://user:password@host:port/database"
DB_SSL=false
# Conteúdo do certificado ca.pem descarregado da consola do Aiven (opcional, recomendado em produção)
DB_SSL_CA=

# Gmail (usar uma "App Password", não a password normal da conta)
MAIL_USERNAME=
MAIL_PASSWORD=

# Notificações push (web-push) — gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:exemplo@dominio.com

# Segredo partilhado para o endpoint de envio de push em massa (components/send_push.php)
PUSH_ADMIN_SECRET=

# URLs públicos desta app (sem barra final), usados em links de email/SMS/WhatsApp.
# Atualizar sempre que mudar de plataforma — não voltar a hardcodar no código.
BACKEND_URL=https://snretratos-backend.onrender.com
FRONTEND_URL=https://frontendsnretratos.onrender.com

# Segredo partilhado com o workflow de cron do GitHub Actions
# (.github/workflows/cron.yml) que chama components/enviar_lembretes.php
# periodicamente. Sem isto o endpoint devolve 403 a qualquer chamada HTTP.
CRON_SECRET=
